{
  "manifest_version": 3,
  "name": "Better Without MAX",
  "version": "1.0.0",
  "description": "Меняет плашку DNS про отсутствие мессенджера MAX на положительную сторону товара.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.dns-shop.ru/*",
        "http://www.dns-shop.ru/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
